rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Shareholders
    match /shareholders/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Installments & Fines
    match /installments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /fines/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Projects
    match /projects/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Costs & Policies
    match /costs/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /policies/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Transactions
    match /transactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
